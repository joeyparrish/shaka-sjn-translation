<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Shaka Player Sindarin Translations</title>
<!--
  Shaka Player Sindarin (Elvish) Translations
  Copyright 2026 Joey Parrish
  SPDX-License-Identifier: Apache-2.0
-->
  <style>
    @font-face {
      font-family: TengwarTelcontar;
      src: url('TengwarTelcontar.woff2') format('woff2');
      unicode-range: U+E000-E0FF;
    }

    body {
      font-family: system-ui, sans-serif;
      max-width: 1400px;
      margin: 2rem auto;
      padding: 0 1.5rem;
      color: #222;
    }

    h1 {
      margin-bottom: 1.5rem;
      font-size: 1.5rem;
      display: flex;
      align-items: center;
      gap: 0.6rem;
    }

    .shaka-link,
    .github-link {
      font-size: 0.9rem;
      color: #888;
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: 0.25rem;
      font-weight: normal;
    }

    .shaka-link:hover,
    .github-link:hover {
      color: #222;
    }

    .shaka-link:not(:hover) path,
    .github-link:not(:hover) path {
      fill: #888;
    }

    .shaka-link svg,
    .github-link svg {
      height: 1.1em;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.9rem;
    }

    th, td {
      text-align: left;
      padding: 0.5rem 0.75rem;
      border-bottom: 1px solid #ddd;
      vertical-align: top;
    }

    th {
      background: #f0f0f0;
      font-weight: 600;
      position: sticky;
      top: 0;
    }

    tr:nth-child(even) td {
      background: #fafafa;
    }

    .col-tengwar {
      font-family: TengwarTelcontar;
      font-size: 1.5em;
    }

    .more-info {
      font-size: 1.5rem;
      line-height: 1;
      padding: 0.1rem 0.3rem;
      cursor: pointer;
      border: none;
      background: transparent;
      color: #666;
    }

    .more-info:hover {
      color: #222;
    }

    /* ── Modal ── */

    dialog {
      border: none;
      border-radius: 8px;
      padding: 0;
      max-width: 680px;
      width: calc(100% - 2rem);
      max-height: 85vh;
      overflow-y: auto;
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
    }

    dialog::backdrop {
      background: rgba(0, 0, 0, 0.4);
    }

    .dialog-inner {
      padding: 1.5rem;
    }

    .dialog-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 0.75rem;
    }

    .dialog-title {
      font-size: 1.25rem;
      margin: 0 0 0.2rem;
    }

    .dialog-key {
      font-size: 0.8rem;
      color: #999;
      font-family: monospace;
    }

    .dialog-close {
      background: none;
      border: none;
      font-size: 1.5rem;
      line-height: 1;
      cursor: pointer;
      color: #999;
      padding: 0 0.25rem;
      flex-shrink: 0;
    }

    .dialog-close:hover {
      color: #222;
    }

    .dialog-translation {
      display: flex;
      gap: 1rem;
      align-items: baseline;
      flex-wrap: wrap;
      margin-bottom: 1.25rem;
      padding-bottom: 1rem;
      border-bottom: 1px solid #eee;
    }

    .dialog-roman {
      color: #444;
      font-style: italic;
    }

    .dialog-tengwar {
      font-family: system-ui, sans-serif, TengwarTelcontar;
      font-size: 1.4em;
    }

    .dialog-elements {
      display: flex;
      flex-direction: column;
      gap: 0.6rem;
      margin-bottom: 1.25rem;
    }

    .element-card {
      background: #f8f8f8;
      border-radius: 4px;
      padding: 0.75rem;
      font-size: 0.875rem;
    }

    .element-form {
      font-weight: 700;
      font-size: 1rem;
      margin-bottom: 0.15rem;
    }

    .element-headword {
      color: #555;
      margin-bottom: 0.4rem;
    }

    .element-meta {
      display: flex;
      gap: 0.5rem;
      align-items: center;
      flex-wrap: wrap;
      margin-bottom: 0.35rem;
    }

    .badge {
      font-size: 0.7rem;
      padding: 0.1rem 0.4rem;
      border-radius: 3px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.03em;
    }

    .badge-attested { background: #d4edda; color: #155724; }
    .badge-coined   { background: #fff3cd; color: #856404; }
    .badge-other    { background: #e2e3e5; color: #383d41; }

    .element-source {
      font-size: 0.8rem;
      color: #888;
      font-family: monospace;
    }

    .element-derivations {
      margin: 0.25rem 0 0.25rem 1.2rem;
      padding: 0;
      color: #555;
    }

    .element-rationale {
      color: #444;
      margin-top: 0.25rem;
    }

    .dialog-footer {
      padding-top: 1rem;
      border-top: 1px solid #eee;
      font-size: 0.875rem;
      display: flex;
      flex-direction: column;
      gap: 0.6rem;
    }

    .dialog-status {
      color: #555;
    }

    .dialog-concerns {
      color: #7a5c00;
      background: #fffbe6;
      border-left: 3px solid #f0c800;
      padding: 0.4rem 0.65rem;
      border-radius: 0 3px 3px 0;
    }

    .dialog-history {
      font-size: 0.8rem;
      color: #777;
    }

    .history-entry {
      display: flex;
      gap: 1rem;
      margin-top: 0.2rem;
    }

    .history-date {
      font-family: monospace;
      white-space: nowrap;
    }

    .source-meta {
      font-size: 0.85rem;
      color: #888;
      margin-top: -1rem;
      margin-bottom: 1.5rem;
    }

    .source-meta a {
      color: #888;
      font-family: monospace;
    }

    .source-meta a:hover {
      color: #222;
    }

    .translation-coverage {
      font-size: 0.85rem;
      color: #888;
      margin-top: -1rem;
      margin-bottom: 1.5rem;
      display: flex;
      align-items: center;
      gap: 0.6rem;
    }

    .coverage-bar {
      display: inline-block;
      width: 120px;
      height: 8px;
      background: #e0e0e0;
      border-radius: 4px;
      overflow: hidden;
      vertical-align: middle;
    }

    .coverage-fill {
      display: block;
      height: 100%;
      background: #ffa519; /* orange: warning */
      border-radius: 4px;
    }

    .coverage-fill.coverage-pct-100 {
      background: #4caf50; /* green: all done */
    }
  </style>
</head>
<body>
  <h1>Shaka Player Sindarin Translations
    <a class="github-link" target="_blank" rel="noopener" href="https://github.com/joeyparrish/shaka-sjn-translation">
      <svg viewBox="0 0 16 16" aria-hidden="true"><path fill="#222" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
      GitHub
    </a>
    <a class="shaka-link" target="_blank" rel="noopener" href="https://shaka-project.github.io/shaka-player/demo/#uilang=sjn;">
      <svg viewBox="6 7 276 157"><path fill="#5294d6" d="M138.204 114.786l12.318 18.968c.059.095.122.189.183.283 6.869 10.576 23.547 12.144 36.35 3.83L252.57 95.32c12.819-8.324 18.153-24.187 11.285-34.764-6.886-10.603-23.205-12.3-36.318-3.783l-48.452 31.465L162.02 99.32z"/><path fill="#5294d6" d="M25.157 77.809c-7.34-11.302-6.772-25.493 1.577-30.915 8.37-5.436 21.354-.415 28.863 11.147l37.555 57.83c7.518 11.577 6.824 25.48-1.546 30.916-8.35 5.423-21.544.169-28.893-11.148z"/><path fill="#3db94b" d="M142.185 50.874c-6.192-9.535-4.329-22.406 4.395-28.072 8.746-5.68 21.076-2.337 27.41 7.418l31.685 48.789c6.343 9.767 4.381 22.39-4.365 28.07-8.724 5.666-21.24 2.132-27.44-7.415z"/><path fill="#fbbc09" d="M110.191 71.652c-6.192-9.535-4.329-22.407 4.395-28.072 8.746-5.68 21.076-2.338 27.41 7.417l31.685 48.79c6.343 9.767 4.381 22.39-4.365 28.07-8.724 5.665-21.24 2.132-27.44-7.416z"/><path fill="#ef3232" d="M78.197 92.43c-6.192-9.536-4.33-22.408 4.395-28.073 8.746-5.68 21.076-2.337 27.41 7.417l31.684 48.79c6.343 9.767 4.382 22.39-4.364 28.07-8.724 5.665-21.24 2.132-27.441-7.416z"/></svg>
      Shaka
    </a>
  </h1>
  {% if source_meta %}
  <p class="source-meta">Source strings: last updated {{ source_meta.date[:10] }} &middot; <a href="https://github.com/shaka-project/shaka-player/commit/{{ source_meta.sha }}" target="_blank" rel="noopener">{{ source_meta.sha[:7] }}</a></p>
  {% endif %}
  <p class="translation-coverage">
    <span class="coverage-bar"><span class="coverage-fill coverage-pct-{{ translation_stats.pct }}" style="width: {{ translation_stats.pct }}%"></span></span>
    {{ translation_stats.pct }}% translated ({{ translation_stats.translated }}&thinsp;/&thinsp;{{ translation_stats.total }} strings)
  </p>
  <table>
    <thead>
      <tr>
        <th>Key</th>
        <th>English</th>
        <th>Literal</th>
        <th>Romanized</th>
        <th>Tengwar</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      {% for item in translations %}
      <tr>
        <td>{{ item.key }}</td>
        <td>{{ item.english }}</td>
        <td>{{ item.sjn.literal }}</td>
        <td>{{ item.sjn.roman }}</td>
        <td class="col-tengwar">{{ item.sjn.tengwar }}</td>
        <td><button class="more-info" data-key="{{ item.key }}">ⓘ</button></td>
      </tr>
      {% endfor %}
    </tbody>
  </table>

  <dialog id="info-dialog">
    <div class="dialog-inner">
      <div class="dialog-header">
        <div>
          <h2 class="dialog-title"></h2>
          <div class="dialog-key"></div>
        </div>
        <button class="dialog-close" aria-label="Close">×</button>
      </div>
      <div class="dialog-translation">
        <span class="dialog-roman"></span>
        <span class="dialog-tengwar"></span>
      </div>
      <div class="dialog-elements"></div>
      <div class="dialog-footer">
        <div class="dialog-status"></div>
        <div class="dialog-concerns"></div>
        <div class="dialog-history"></div>
      </div>
    </div>
  </dialog>

  <script type="application/json" id="translations-data">
  {{ translations_json | safe }}
  </script>

  <script>
    const data = JSON.parse(document.getElementById('translations-data').textContent);
    const byKey = Object.fromEntries(data.map(t => [t.key, t]));
    const dialog = document.getElementById('info-dialog');

    function esc(str) {
      const el = document.createElement('span');
      el.textContent = String(str);
      return el.innerHTML;
    }

    function renderModal(t) {
      dialog.querySelector('.dialog-title').textContent = t.english;
      dialog.querySelector('.dialog-key').textContent = t.key;
      dialog.querySelector('.dialog-roman').textContent = t.sjn.roman;
      dialog.querySelector('.dialog-tengwar').textContent = t.sjn.tengwar;

      const elementsEl = dialog.querySelector('.dialog-elements');
      elementsEl.innerHTML = (t.elements || []).map(el => {
        const badgeClass = el.attestation === 'attested' ? 'badge-attested'
                         : el.attestation === 'coined'   ? 'badge-coined'
                         : 'badge-other';
        const derivations = (el.derivations || []).length
          ? `<ul class="element-derivations">${el.derivations.map(d => `<li>${esc(d)}</li>`).join('')}</ul>`
          : '';
        return `<div class="element-card">
          <div class="element-form">${esc(el.form)}</div>
          <div class="element-headword">${esc(el.headword)} — ${esc(el['headword-meaning'])}</div>
          <div class="element-meta">
            <span class="badge ${badgeClass}">${esc(el.attestation)}</span>
            <span class="element-source">${esc(el.source)}</span>
          </div>
          ${derivations}
          <div class="element-rationale">${esc(el.rationale)}</div>
        </div>`;
      }).join('');

      const statusEl = dialog.querySelector('.dialog-status');
      statusEl.innerHTML = t.status ? `<strong>Status:</strong> ${esc(t.status)}` : '';
      statusEl.hidden = !t.status;

      const concernsEl = dialog.querySelector('.dialog-concerns');
      concernsEl.textContent = t.concerns || '';
      concernsEl.hidden = !t.concerns;

      const historyEl = dialog.querySelector('.dialog-history');
      if (t.history && t.history.length) {
        historyEl.innerHTML = '<strong>History</strong>'
          + t.history.map(h =>
              `<div class="history-entry">
                <span class="history-date">${esc(h.date)}</span>
                <span>${esc(h.note)}</span>
              </div>`
            ).join('');
        historyEl.hidden = false;
      } else {
        historyEl.hidden = true;
      }
    }

    document.querySelectorAll('.more-info').forEach(btn => {
      btn.addEventListener('click', () => {
        const t = byKey[btn.dataset.key];
        if (t) {
          renderModal(t);
          dialog.showModal();
        }
      });
    });

    dialog.querySelector('.dialog-close').addEventListener('click', () => dialog.close());

    dialog.addEventListener('click', e => {
      if (e.target === dialog) dialog.close();
    });
  </script>
</body>
</html>
